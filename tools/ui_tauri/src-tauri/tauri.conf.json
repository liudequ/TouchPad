{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TouchpadConfigUI",
  "version": "0.1.0",
  "identifier": "com.touchpad.configui",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../web"
  },
